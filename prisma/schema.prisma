// Documentation-only schema mirror for the PostgreSQL tables used via direct `pg` SQL.
// This project does not use Prisma Client or ORM code generation.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  website   String?
  industry  String?
  createdAt DateTime @default(now()) @map("created_at")
  reports   Report[]

  @@map("companies")
}

model Report {
  id                  BigInt   @id @default(autoincrement())
  companyId           BigInt   @map("company_id")
  roleTitle           String   @map("role_title")
  candidateFunction   String   @map("candidate_function")
  candidateLevel      String   @map("candidate_level")
  interviewStage      String   @map("interview_stage")
  interviewCount      Int      @map("interview_count")
  daysWaited          Int      @map("days_waited")
  lastContactDate     DateTime @map("last_contact_date") @db.Date
  location            String?
  experience          String
  eventualResponse    Boolean  @default(false) @map("eventual_response")
  publicConsent       Boolean  @default(true) @map("public_consent")
  reporterFingerprint String?  @map("reporter_fingerprint")
  createdAt           DateTime @default(now()) @map("created_at")
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model PaidAccess {
  id                      BigInt   @id @default(autoincrement())
  email                   String   @unique
  status                  String
  source                  String
  stripeCustomerId        String?  @map("stripe_customer_id")
  stripeCheckoutSessionId String?  @unique @map("stripe_checkout_session_id")
  amountTotal             Int?     @map("amount_total")
  currency                String?
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("paid_access")
}
